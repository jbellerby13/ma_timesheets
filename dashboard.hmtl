<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MA Externship — Coordinator Dashboard</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --navy: #0f1e2e;
    --navy-mid: #1a2f45;
    --teal: #1e8c7a;
    --teal-light: #25b09a;
    --gold: #d4a843;
    --gold-light: #e8c068;
    --cream: #f8f4ed;
    --cream-dark: #ede8df;
    --text: #1a1a2e;
    --text-mid: #4a5568;
    --text-light: #718096;
    --white: #ffffff;
    --error: #c0392b;
    --border: #d4cfc4;
    --shadow: 0 4px 24px rgba(15,30,46,0.10);
    --pending: #e67e22;
    --approved: #1e8c7a;
    --returned: #c0392b;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--cream);
    color: var(--text);
    min-height: 100vh;
  }

  .header {
    background: var(--navy);
    padding: 18px 32px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    box-shadow: 0 2px 12px rgba(0,0,0,0.2);
  }
  .header-left { display: flex; align-items: center; gap: 14px; }
  .header-logo {
    width: 40px; height: 40px;
    background: var(--teal);
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    font-size: 20px;
  }
  .header-title {
    font-family: 'DM Serif Display', serif;
    color: var(--white);
    font-size: 1.25rem;
  }
  .header-subtitle {
    color: rgba(255,255,255,0.5);
    font-size: 0.78rem;
    margin-top: 1px;
  }
  .header-btn {
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.2);
    color: white;
    padding: 8px 16px;
    border-radius: 8px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.85rem;
    cursor: pointer;
    text-decoration: none;
    transition: background 0.2s;
  }
  .header-btn:hover { background: rgba(255,255,255,0.2); }

  /* LOGIN */
  #login-screen {
    max-width: 420px;
    margin: 80px auto;
    padding: 0 20px;
  }
  .login-card {
    background: var(--white);
    border-radius: 16px;
    box-shadow: var(--shadow);
    overflow: hidden;
  }
  .login-card-header {
    background: var(--navy);
    padding: 28px;
    text-align: center;
  }
  .login-card-header h2 {
    font-family: 'DM Serif Display', serif;
    color: white;
    font-size: 1.4rem;
    margin-bottom: 6px;
  }
  .login-card-header p { color: rgba(255,255,255,0.6); font-size: 0.85rem; }
  .login-card-body { padding: 28px; }
  .field { display: flex; flex-direction: column; gap: 6px; margin-bottom: 18px; }
  .field label { font-size: 0.78rem; font-weight: 600; color: var(--text-mid); text-transform: uppercase; letter-spacing: 0.07em; }
  .field input {
    padding: 11px 14px;
    border: 1.5px solid var(--border);
    border-radius: 9px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.92rem;
    background: var(--cream);
    outline: none;
    transition: border-color 0.2s;
  }
  .field input:focus { border-color: var(--teal); background: white; }
  .login-btn {
    width: 100%;
    padding: 13px;
    background: var(--teal);
    color: white;
    font-family: 'DM Serif Display', serif;
    font-size: 1.05rem;
    border: none;
    border-radius: 10px;
    cursor: pointer;
    transition: background 0.2s;
  }
  .login-btn:hover { background: var(--teal-light); }
  .login-error { color: var(--error); font-size: 0.85rem; margin-top: 10px; display: none; }

  /* MAIN DASHBOARD */
  #dashboard { display: none; }
  .main { max-width: 1200px; margin: 40px auto; padding: 0 24px 80px; }

  /* STATS ROW */
  .stats-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    margin-bottom: 28px;
  }
  @media (max-width: 768px) { .stats-row { grid-template-columns: 1fr 1fr; } }
  .stat-card {
    background: var(--white);
    border-radius: 14px;
    padding: 20px 22px;
    box-shadow: var(--shadow);
  }
  .stat-label { font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.07em; color: var(--text-light); margin-bottom: 8px; }
  .stat-value { font-family: 'DM Serif Display', serif; font-size: 2rem; color: var(--navy); line-height: 1; }
  .stat-sub { font-size: 0.78rem; color: var(--text-light); margin-top: 4px; }

  /* FILTERS */
  .filters {
    background: var(--white);
    border-radius: 14px;
    padding: 18px 22px;
    box-shadow: var(--shadow);
    margin-bottom: 24px;
    display: flex;
    gap: 14px;
    align-items: center;
    flex-wrap: wrap;
  }
  .filters input, .filters select {
    padding: 9px 14px;
    border: 1.5px solid var(--border);
    border-radius: 8px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.88rem;
    background: var(--cream);
    outline: none;
    flex: 1;
    min-width: 160px;
  }
  .filters input:focus, .filters select:focus { border-color: var(--teal); background: white; }
  .refresh-btn {
    padding: 9px 18px;
    background: var(--teal);
    color: white;
    border: none;
    border-radius: 8px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.88rem;
    font-weight: 600;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.2s;
  }
  .refresh-btn:hover { background: var(--teal-light); }

  /* STUDENT CARDS */
  .student-card {
    background: var(--white);
    border-radius: 14px;
    box-shadow: var(--shadow);
    margin-bottom: 20px;
    overflow: hidden;
  }
  .student-header {
    background: var(--navy);
    padding: 16px 22px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    cursor: pointer;
    user-select: none;
  }
  .student-header:hover { background: var(--navy-mid); }
  .student-name { font-family: 'DM Serif Display', serif; color: white; font-size: 1.05rem; }
  .student-meta { color: rgba(255,255,255,0.6); font-size: 0.8rem; margin-top: 2px; }
  .student-right { display: flex; align-items: center; gap: 14px; }
  .total-badge {
    background: var(--teal);
    color: white;
    padding: 6px 14px;
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 600;
  }
  .chevron { color: rgba(255,255,255,0.6); font-size: 18px; transition: transform 0.2s; }
  .chevron.open { transform: rotate(180deg); }

  .student-body { display: none; padding: 0; }
  .student-body.open { display: block; }

  /* WEEKS TABLE */
  .weeks-table { width: 100%; border-collapse: collapse; font-size: 0.88rem; }
  .weeks-table th {
    background: var(--cream-dark);
    color: var(--text-mid);
    font-size: 0.73rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 10px 16px;
    text-align: left;
  }
  .weeks-table td { padding: 12px 16px; border-bottom: 1px solid var(--cream-dark); vertical-align: middle; }
  .weeks-table tr:last-child td { border-bottom: none; }
  .weeks-table tr:hover td { background: var(--cream); }

  .status-badge {
    display: inline-block;
    padding: 3px 10px;
    border-radius: 12px;
    font-size: 0.75rem;
    font-weight: 700;
  }
  .status-Pending { background: #fef3e2; color: var(--pending); }
  .status-Approved { background: #e6f7f4; color: var(--approved); }
  .status-Returned { background: #fdecea; color: var(--returned); }

  .view-btn {
    background: none;
    border: 1.5px solid var(--teal);
    color: var(--teal);
    padding: 5px 12px;
    border-radius: 7px;
    font-size: 0.78rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.15s;
  }
  .view-btn:hover { background: var(--teal); color: white; }

  /* LOADING */
  .loading { text-align: center; padding: 60px; color: var(--text-light); font-size: 0.95rem; }
  .spinner-lg {
    width: 36px; height: 36px;
    border: 3px solid var(--cream-dark);
    border-top-color: var(--teal);
    border-radius: 50%;
    animation: spin 0.7s linear infinite;
    margin: 0 auto 16px;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* MODAL */
  .modal-overlay {
    display: none;
    position: fixed; inset: 0;
    background: rgba(15,30,46,0.6);
    z-index: 100;
    align-items: center;
    justify-content: center;
    padding: 20px;
  }
  .modal-overlay.open { display: flex; }
  .modal {
    background: var(--white);
    border-radius: 16px;
    max-width: 700px;
    width: 100%;
    max-height: 85vh;
    overflow-y: auto;
    box-shadow: var(--shadow);
  }
  .modal-header {
    background: var(--navy);
    padding: 20px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: sticky; top: 0;
  }
  .modal-header h3 { font-family: 'DM Serif Display', serif; color: white; font-size: 1.1rem; }
  .modal-close { background: none; border: none; color: rgba(255,255,255,0.6); font-size: 22px; cursor: pointer; }
  .modal-close:hover { color: white; }
  .modal-body { padding: 24px; }
  .info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-bottom: 20px; }
  .info-item { background: var(--cream); border-radius: 10px; padding: 12px 16px; }
  .info-item .label { font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.07em; color: var(--text-light); margin-bottom: 4px; }
  .info-item .value { font-size: 0.92rem; color: var(--text); font-weight: 500; }
  .hours-detail-table { width: 100%; border-collapse: collapse; font-size: 0.85rem; margin-top: 16px; }
  .hours-detail-table th { background: var(--navy); color: rgba(255,255,255,0.8); padding: 9px 12px; text-align: left; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.05em; }
  .hours-detail-table td { padding: 9px 12px; border-bottom: 1px solid var(--cream-dark); }
  .hours-detail-table tr:last-child td { border-bottom: none; }
  .notes-box { background: #fef3e2; border: 1px solid #f5d99c; border-radius: 10px; padding: 14px 16px; margin-top: 16px; font-size: 0.88rem; color: var(--text-mid); }
  .notes-box strong { color: var(--pending); }
</style>
</head>
<body>

<div class="header">
  <div class="header-left">
    <div class="header-logo">🏥</div>
    <div>
      <div class="header-title">Coordinator Dashboard</div>
      <div class="header-subtitle">MA Externship Program — Prism Career Institute</div>
    </div>
  </div>
  <a href="/" class="header-btn">← Back to Timesheet</a>
</div>

<!-- LOGIN -->
<div id="login-screen">
  <div class="login-card">
    <div class="login-card-header">
      <h2>Coordinator Access</h2>
      <p>Enter your credentials to view the dashboard</p>
    </div>
    <div class="login-card-body">
      <div class="field">
        <label>Email</label>
        <input type="email" id="login-email" placeholder="your@prismcareerinstitute.edu" />
      </div>
      <div class="field">
        <label>Password</label>
        <input type="password" id="login-password" placeholder="Enter password" onkeydown="if(event.key==='Enter') login()" />
      </div>
      <button class="login-btn" onclick="login()">Access Dashboard</button>
      <div class="login-error" id="login-error">Incorrect email or password.</div>
    </div>
  </div>
</div>

<!-- DASHBOARD -->
<div id="dashboard">
  <div class="main">

    <!-- Stats -->
    <div class="stats-row">
      <div class="stat-card">
        <div class="stat-label">Total Students</div>
        <div class="stat-value" id="stat-students">—</div>
        <div class="stat-sub">unique students</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Total Submissions</div>
        <div class="stat-value" id="stat-submissions">—</div>
        <div class="stat-sub">weekly timesheets</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Pending Approval</div>
        <div class="stat-value" id="stat-pending" style="color:var(--pending);">—</div>
        <div class="stat-sub">awaiting supervisor</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Total Hours Logged</div>
        <div class="stat-value" id="stat-hours" style="color:var(--teal);">—</div>
        <div class="stat-sub">across all students</div>
      </div>
    </div>

    <!-- Filters -->
    <div class="filters">
      <input type="text" id="filter-name" placeholder="🔍 Search by student name..." oninput="renderStudents()" />
      <select id="filter-status" onchange="renderStudents()">
        <option value="">All statuses</option>
        <option value="Pending">Pending</option>
        <option value="Approved">Approved</option>
        <option value="Returned for Correction">Returned for Correction</option>
      </select>
      <select id="filter-site" onchange="renderStudents()">
        <option value="">All sites</option>
      </select>
      <button class="refresh-btn" onclick="loadData()">↻ Refresh</button>
    </div>

    <!-- Student List -->
    <div id="student-list">
      <div class="loading">
        <div class="spinner-lg"></div>
        Loading submissions...
      </div>
    </div>

  </div>
</div>

<!-- DETAIL MODAL -->
<div class="modal-overlay" id="modal">
  <div class="modal">
    <div class="modal-header">
      <h3 id="modal-title">Timesheet Detail</h3>
      <button class="modal-close" onclick="closeModal()">✕</button>
    </div>
    <div class="modal-body" id="modal-body"></div>
  </div>
</div>

<script>
// ─── CONFIG ───────────────────────────────────────────────────────────────────
const SUPABASE_URL = 'https://kekcernztojfjknyquiv.supabase.co';
const SUPABASE_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Imtla2Nlcm56dG9qZmprbnlxdWl2Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzU1MTA0MTAsImV4cCI6MjA5MTA4NjQxMH0.1EOlhuCnH0NTywKrtxlDfmX8T0-lyjKk8JiuvF1XzVQ';

// Simple coordinator credentials — change these to your own
const COORDINATORS = [
  { email: 'jbellerby@prismcareerinstitute.edu', password: 'Prism2024!' }
];

let allData = [];

// ─── LOGIN ────────────────────────────────────────────────────────────────────
function login() {
  const email = document.getElementById('login-email').value.trim().toLowerCase();
  const password = document.getElementById('login-password').value;
  const match = COORDINATORS.find(c => c.email.toLowerCase() === email && c.password === password);
  if (match) {
    document.getElementById('login-screen').style.display = 'none';
    document.getElementById('dashboard').style.display = 'block';
    loadData();
  } else {
    document.getElementById('login-error').style.display = 'block';
  }
}

// ─── LOAD DATA ────────────────────────────────────────────────────────────────
async function loadData() {
  document.getElementById('student-list').innerHTML = `
    <div class="loading"><div class="spinner-lg"></div>Loading submissions...</div>`;
  try {
    const resp = await fetch(`${SUPABASE_URL}/rest/v1/timesheets?select=*&order=created_at.desc`, {
      headers: {
        'apikey': SUPABASE_KEY,
        'Authorization': `Bearer ${SUPABASE_KEY}`
      }
    });
    allData = await resp.json();
    updateStats();
    populateSiteFilter();
    renderStudents();
  } catch(e) {
    document.getElementById('student-list').innerHTML = `<div class="loading">Error loading data. Please refresh.</div>`;
  }
}

// ─── STATS ────────────────────────────────────────────────────────────────────
function updateStats() {
  const students = new Set(allData.map(r => r.student_email)).size;
  const pending = allData.filter(r => r.status === 'Pending').length;
  const totalHrs = allData.reduce((sum, r) => sum + (parseFloat(r.total_hrs) || 0), 0);
  document.getElementById('stat-students').textContent = students;
  document.getElementById('stat-submissions').textContent = allData.length;
  document.getElementById('stat-pending').textContent = pending;
  document.getElementById('stat-hours').textContent = totalHrs.toFixed(1);
}

// ─── SITE FILTER ──────────────────────────────────────────────────────────────
function populateSiteFilter() {
  const sites = [...new Set(allData.map(r => r.site_name).filter(Boolean))].sort();
  const sel = document.getElementById('filter-site');
  sel.innerHTML = '<option value="">All sites</option>';
  sites.forEach(s => {
    const opt = document.createElement('option');
    opt.value = s; opt.textContent = s;
    sel.appendChild(opt);
  });
}

// ─── RENDER STUDENTS ──────────────────────────────────────────────────────────
function renderStudents() {
  const nameFilter = document.getElementById('filter-name').value.toLowerCase();
  const statusFilter = document.getElementById('filter-status').value;
  const siteFilter = document.getElementById('filter-site').value;

  let filtered = allData.filter(r => {
    const nameMatch = !nameFilter || r.student_name?.toLowerCase().includes(nameFilter);
    const statusMatch = !statusFilter || r.status === statusFilter;
    const siteMatch = !siteFilter || r.site_name === siteFilter;
    return nameMatch && statusMatch && siteMatch;
  });

  // Group by student email
  const grouped = {};
  filtered.forEach(r => {
    const key = r.student_email || r.student_name;
    if (!grouped[key]) grouped[key] = [];
    grouped[key].push(r);
  });

  const container = document.getElementById('student-list');
  if (Object.keys(grouped).length === 0) {
    container.innerHTML = `<div class="loading">No submissions found.</div>`;
    return;
  }

  container.innerHTML = '';
  Object.entries(grouped).forEach(([key, records]) => {
    const student = records[0];
    const totalHrs = records.reduce((sum, r) => sum + (parseFloat(r.total_hrs) || 0), 0);
    const pending = records.filter(r => r.status === 'Pending').length;

    const card = document.createElement('div');
    card.className = 'student-card';
    card.innerHTML = `
      <div class="student-header" onclick="toggleStudent('${key}')">
        <div>
          <div class="student-name">${student.student_name}</div>
          <div class="student-meta">${student.student_email} · ${student.site_name}${pending > 0 ? ` · <span style="color:#e8c068;">${pending} pending</span>` : ''}</div>
        </div>
        <div class="student-right">
          <div class="total-badge">${totalHrs.toFixed(2)} hrs total</div>
          <div class="chevron" id="chev-${CSS.escape(key)}">▼</div>
        </div>
      </div>
      <div class="student-body" id="body-${CSS.escape(key)}">
        <table class="weeks-table">
          <thead>
            <tr>
              <th>Week</th>
              <th>Submitted</th>
              <th>Hours</th>
              <th>Status</th>
              <th>Notes</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            ${records.map(r => `
              <tr>
                <td>${r.week_label || '—'}</td>
                <td>${new Date(r.created_at).toLocaleDateString()}</td>
                <td style="font-weight:600;color:var(--teal);">${parseFloat(r.total_hrs).toFixed(2)}</td>
                <td><span class="status-badge status-${r.status?.replace(/ .*/,'')}">${r.status || 'Pending'}</span></td>
                <td style="font-size:0.82rem;color:var(--text-mid);max-width:200px;">${r.supervisor_notes ? r.supervisor_notes.substring(0,60) + (r.supervisor_notes.length > 60 ? '...' : '') : '—'}</td>
                <td><button class="view-btn" onclick="viewDetail(${r.id})">View</button></td>
              </tr>
            `).join('')}
          </tbody>
        </table>
      </div>
    `;
    container.appendChild(card);
  });
}

function toggleStudent(key) {
  const body = document.getElementById(`body-${CSS.escape(key)}`);
  const chev = document.getElementById(`chev-${CSS.escape(key)}`);
  body.classList.toggle('open');
  chev.classList.toggle('open');
}

// ─── DETAIL MODAL ─────────────────────────────────────────────────────────────
function viewDetail(id) {
  const r = allData.find(x => x.id === id);
  if (!r) return;

  let rowsHtml = '';
  try {
    const rows = JSON.parse(r.rows_data || '[]');
    rowsHtml = rows.filter(row => row.date).map(row => `
      <tr>
        <td>${row.day || '—'}</td>
        <td>${formatDate(row.date)}</td>
        <td>${formatTime(row.timeIn)}</td>
        <td>${formatTime(row.timeOut)}</td>
        <td>${row.breakMins ? row.breakMins + ' min' : '—'}</td>
        <td style="font-weight:600;color:var(--teal);">${(row.hrs||0).toFixed(2)}</td>
      </tr>
    `).join('');
  } catch(e) {}

  document.getElementById('modal-title').textContent = `${r.student_name} — ${r.week_label || 'Timesheet'}`;
  document.getElementById('modal-body').innerHTML = `
    <div class="info-grid">
      <div class="info-item"><div class="label">Student</div><div class="value">${r.student_name}</div></div>
      <div class="info-item"><div class="label">Email</div><div class="value">${r.student_email}</div></div>
      <div class="info-item"><div class="label">Externship Site</div><div class="value">${r.site_name}</div></div>
      <div class="info-item"><div class="label">Supervisor</div><div class="value">${r.supervisor_name}</div></div>
      <div class="info-item"><div class="label">Submitted</div><div class="value">${new Date(r.created_at).toLocaleDateString()}</div></div>
      <div class="info-item"><div class="label">Status</div><div class="value"><span class="status-badge status-${r.status?.replace(/ .*/,'')}">${r.status}</span></div></div>
    </div>
    <table class="hours-detail-table">
      <thead>
        <tr><th>Day</th><th>Date</th><th>Time In</th><th>Time Out</th><th>Break</th><th>Net Hours</th></tr>
      </thead>
      <tbody>${rowsHtml}</tbody>
      <tfoot>
        <tr style="background:var(--navy);">
          <td colspan="5" style="color:rgba(255,255,255,0.7);padding:10px 12px;font-weight:600;">Total Net Hours</td>
          <td style="color:var(--gold-light);font-weight:700;padding:10px 12px;font-size:1.05rem;">${parseFloat(r.total_hrs).toFixed(2)}</td>
        </tr>
      </tfoot>
    </table>
    ${r.supervisor_notes ? `<div class="notes-box"><strong>Supervisor Notes:</strong><br>${r.supervisor_notes}</div>` : ''}
    <div style="margin-top:16px;">
      <a href="${r.approval_url}" target="_blank" style="color:var(--teal);font-size:0.85rem;">🔗 Open Approval Link</a>
    </div>
  `;
  document.getElementById('modal').classList.add('open');
}

function closeModal() {
  document.getElementById('modal').classList.remove('open');
}

document.getElementById('modal').addEventListener('click', function(e) {
  if (e.target === this) closeModal();
});

// ─── HELPERS ──────────────────────────────────────────────────────────────────
function formatDate(d) {
  if (!d) return '—';
  const [y, m, day] = d.split('-');
  const months = ['January','February','March','April','May','June','July','August','September','October','November','December'];
  return `${months[parseInt(m,10)-1]} ${parseInt(day,10)}, ${y}`;
}
function formatTime(t) {
  if (!t) return '—';
  const [h, m] = t.split(':').map(Number);
  const ampm = h >= 12 ? 'PM' : 'AM';
  const hr = h % 12 || 12;
  return `${hr}:${String(m).padStart(2,'0')} ${ampm}`;
}
</script>
</body>
</html>
